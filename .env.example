# Copy this file to ".env" and fill in the values.
# cp .env.example .env

# Port the server listens on
PORT=3000

# ─── Email (optional) ────────────────────────────────────────────────
# Leave these blank to keep email disabled. Responses are always saved
# to the dashboard regardless. Fill them in to also receive an email
# for every response.
#
# Example for a Gmail account using an App Password
# (https://myaccount.google.com/apppasswords):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   EMAIL_TO=youraddress@gmail.com
#   EMAIL_FROM=youraddress@gmail.com

SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_TO=
EMAIL_FROM=
