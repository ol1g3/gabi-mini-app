# Copy this file to ".env" and fill in the values.
# cp .env.example .env

# Port the server listens on
PORT=3000

# ─── Dashboard access ────────────────────────────────────────────────
# The password required to view the dashboard. CHANGE THIS.
DASHBOARD_PASSWORD=changeme

# Secret used to sign login cookies. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=please-change-this-to-a-long-random-string

# ─── Email (optional) ────────────────────────────────────────────────
# Leave these blank to keep email disabled. Responses are always saved
# to the dashboard regardless. Fill them in to also receive an email
# for every response.
#
# Example for a Gmail account using an App Password
# (https://myaccount.google.com/apppasswords):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   EMAIL_TO=youraddress@gmail.com
#   EMAIL_FROM=youraddress@gmail.com

SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_TO=
EMAIL_FROM=
